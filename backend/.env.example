NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/qease?retryWrites=true&w=majority
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Browser Origin(s) for CORS (comma-separated). Use your real Vercel URL(s), not the API host.
# FRONTEND_URL is merged into the allowlist if ALLOWED_ORIGINS is unset.
FRONTEND_URL=https://q-ease-queue-management-system.vercel.app
# ALLOWED_ORIGINS=https://q-ease-queue-management-system.vercel.app,http://localhost:5173

# Notification Services (Mock mode for demo)
TWILIO_ACCOUNT_SID=mock_sid
TWILIO_AUTH_TOKEN=mock_token
TWILIO_PHONE_NUMBER=+1234567890
EMAIL_USER=mock@email.com
EMAIL_PASS=mock_password

# Demo Mode
DEMO_MODE=true
MOCK_NOTIFICATIONS=true
