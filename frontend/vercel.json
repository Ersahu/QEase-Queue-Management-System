{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://qease-queue-management-system-1.onrender.com/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://qease-queue-management-system-1.onrender.com/socket.io/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/"
    }
  ]
}
